<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.RawDepthCodelabActivity">

    <android.opengl.GLSurfaceView
        android:id="@+id/surfaceview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageButton
        android:id="@+id/back_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:backgroundTint="@android:color/transparent"
        android:contentDescription="@string/back_button_description"
        android:elevation="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_arrow_back"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/top_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:gravity="end"
        android:orientation="vertical">

        <Button
            android:id="@+id/toggleModeButtonCamera"
            android:layout_width="104dp"
            android:layout_height="44dp"
            android:background="@drawable/button_selector"
            android:text="@string/toggleButtonCameraText"
            android:textColor="@color/total_white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/togglePlanesFilteringButton"
            android:layout_width="104dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_selector"
            android:text="Planes"
            android:textColor="@color/total_white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/settingsToggleButton"
            android:layout_width="104dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_selector"
            android:text="Settings"
            android:textColor="@color/total_white"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_controls"
        android:layout_width="96dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center|end"
        android:layout_marginEnd="12dp"
        android:gravity="center"
        android:orientation="vertical">

        <Button
            android:id="@+id/testButton1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Scan"
            android:textSize="13sp" />

        <Button
            android:id="@+id/testButton3"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Create"
            android:textSize="13sp" />

        <Button
            android:id="@+id/point_reset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Reset"
            android:textSize="13sp" />

        <Button
            android:id="@+id/testButton2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Test"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/points_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#66000000"
            android:gravity="center"
            android:padding="6dp"
            android:text="P : 0"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_gravity="bottom"
        android:background="#CC101010"
        android:fillViewport="false"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan settings"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/amountOfPointsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Max points"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/amountOfPointsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="400000"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/amountOfPointsSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000000"
                android:progress="400000" />

            <TextView
                android:id="@+id/pointsToRenderLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Points to render"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/pointsToRenderValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20000"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/pointsToRenderSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100000"
                android:progress="20000" />

            <TextView
                android:id="@+id/depthThresholdLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max depth"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/depthThresholdValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.50"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/depthThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="3000"
                android:progress="1500" />

            <TextView
                android:id="@+id/confidenceThresholdLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidence"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/confidenceThresholdValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.30"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/confidenceThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="30" />

            <TextView
                android:id="@+id/increaseThresholdLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plane distance"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/increaseThresholdValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.03"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/increaseThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="3" />

            <TextView
                android:id="@+id/minDepthThresholdLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Min depth"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/minDepthThresholdValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.20"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/minDepthThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="20" />

            <TextView
                android:id="@+id/edgeFilterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edge filter"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/edgeFilterValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.08"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/edgeFilterSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="20"
                android:progress="8" />

            <TextView
                android:id="@+id/voxelSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voxel size"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/voxelSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.010"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/voxelSizeSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="10" />

            <TextView
                android:id="@+id/stabilityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Point stability"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/stabilityValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="@android:color/white" />

            <SeekBar
                android:id="@+id/stabilitySeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="6"
                android:progress="2" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
